{
  "name": "cloudflare-onedrive-live-mcp",
  "version": "0.2.0",
  "private": true,
  "description": "Read-only remote MCP server for live personal OneDrive search and on-demand file reading through Cloudflare Workers.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "verify-config": "node scripts/verify-config.mjs",
    "type-check": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "check": "npm run type-check && npm test",
    "predeploy": "npm run verify-config && npm run check",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "0.8.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "agents": "0.17.4",
    "fflate": "0.8.2",
    "hono": "4.12.30",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260628.1",
    "@types/node": "24.0.0",
    "tsx": "4.20.0",
    "typescript": "6.0.3",
    "wrangler": "4.105.0"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
